rules_version = '2';

// Files live under `users/<uid>/events/<eventId>/<fileId>/{original|compressed}.<ext>`.
// Photographers read/write their own folder. Clients download via the
// long-lived download tokens that `getDownloadURL` bakes into each URL —
// they never talk to Storage through these rules directly.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null
        && request.auth.uid == uid;
    }
  }
}
